{
  "name": "sword-card-creator",
  "version": "1.0.0",
  "description": "A tool for creating cards for untitled Sword Card Game ",
  "author": "Wesley Ho",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./build/build.js",
    "serve": "node ./build/serve.js",
    "validate": "npm run build && node ./dist/validate.js",
    "schema": "npm run build && node ./dist/createSchema.js",
    "deck": "npm run build && node ./dist/deckBuilder.js",
    "tts": "npm run build && node ./dist/ttsImageStitcher.js",
    "image": "npm run build && node ./dist/generateImages.js",
    "upload": "npm run build && node ./dist/upload.js",
    "csv": "npm run build && node ./dist/convertCsv.js",
    "pdf": "npm run build && node ./dist/createPdf.js"
  },
  "dependencies": {
    "@jpinsonneau/html-to-image": "^1.11.13",
    "consola": "^3.4.2",
    "csv-parse": "^6.1.0",
    "json-stringify-pretty-compact": "^4.0.0",
    "minimist": "^1.2.8",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.31.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.8.1",
    "esbuild": "^0.25.11",
    "esbuild-plugin-tsc": "^0.5.0",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "sharp": "^0.34.5"
  }
}
